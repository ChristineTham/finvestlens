<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSFaceIDUsageDescription</key>
	<string>Authenticate to unlock your FinvestLens book.</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>FinvestLens Book</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.hellotham.finvestlens.document</string>
			</array>
			<key>NSUbiquitousDocumentUserActivityType</key>
			<string>$(PRODUCT_BUNDLE_IDENTIFIER).document</string>
		</dict>
		<dict>
			<!-- The sibling .lock file is a "related item" of the book: the
			     sandbox extends user-selected access to it (FileLock uses
			     NSFileCoordinator with a related-item presenter). -->
			<key>CFBundleTypeName</key>
			<string>FinvestLens Lock File</string>
			<key>CFBundleTypeRole</key>
			<string>None</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>lock</string>
			</array>
			<key>NSIsRelatedItemType</key>
			<true/>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.database</string>
			</array>
			<key>UTTypeDescription</key>
			<string>FinvestLens Book</string>
			<key>UTTypeIdentifier</key>
			<string>com.hellotham.finvestlens.document</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>finvestlens</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
